<?xml version="1.0" encoding="utf-8"?>
<robot name="upkie">
  <link name="base">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="2.500000"/>
      <inertia ixx="1.200000e-2" iyy="1.500000e-2" izz="8.000000e-3" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="L_upper_leg">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.350000"/>
      <inertia ixx="1.000000e-3" iyy="1.000000e-3" izz="8.000000e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="L_lower_leg">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.250000"/>
      <inertia ixx="6.500000e-4" iyy="6.500000e-4" izz="5.000000e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="L_wheel">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.300000"/>
      <inertia ixx="3.000000e-4" iyy="5.500000e-4" izz="3.000000e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="R_upper_leg">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.350000"/>
      <inertia ixx="1.000000e-3" iyy="1.000000e-3" izz="8.000000e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="R_lower_leg">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.250000"/>
      <inertia ixx="6.500000e-4" iyy="6.500000e-4" izz="5.000000e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="R_wheel">
    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.300000"/>
      <inertia ixx="3.000000e-4" iyy="5.500000e-4" izz="3.000000e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="L_HIP_pitch" type="revolute">
    <parent link="base"/>
    <child link="L_upper_leg"/>
    <origin xyz="0.000000 0.080000 -0.040000" rpy="0.000000 0.000000 0.000000"/>
    <axis xyz="0.000000 1.000000 0.000000"/>
    <limit lower="-1.500" upper="1.500" effort="18.000" velocity="30.000"/>
  </joint>
  <transmission name="L_HIP_pitch_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="L_HIP_pitch">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="L_HIP_pitch_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <joint name="L_KNEE_pitch" type="revolute">
    <parent link="L_upper_leg"/>
    <child link="L_lower_leg"/>
    <origin xyz="0.000000 0.000000 -0.115000" rpy="0.000000 0.000000 0.000000"/>
    <axis xyz="0.000000 1.000000 0.000000"/>
    <limit lower="-2.500" upper="2.500" effort="18.000" velocity="30.000"/>
  </joint>
  <transmission name="L_KNEE_pitch_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="L_KNEE_pitch">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="L_KNEE_pitch_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <joint name="L_WHEEL_drive" type="continuous">
    <parent link="L_lower_leg"/>
    <child link="L_wheel"/>
    <origin xyz="0.000000 0.000000 -0.115000" rpy="-1.570796 0.000000 0.000000"/>
    <axis xyz="0.000000 0.000000 1.000000"/>
    <limit effort="8.000" velocity="60.000"/>
  </joint>
  <transmission name="L_WHEEL_drive_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="L_WHEEL_drive">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="L_WHEEL_drive_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <joint name="R_HIP_pitch" type="revolute">
    <parent link="base"/>
    <child link="R_upper_leg"/>
    <origin xyz="0.000000 -0.080000 -0.040000" rpy="0.000000 0.000000 0.000000"/>
    <axis xyz="0.000000 1.000000 0.000000"/>
    <limit lower="-1.500" upper="1.500" effort="18.000" velocity="30.000"/>
  </joint>
  <transmission name="R_HIP_pitch_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="R_HIP_pitch">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="R_HIP_pitch_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <joint name="R_KNEE_pitch" type="revolute">
    <parent link="R_upper_leg"/>
    <child link="R_lower_leg"/>
    <origin xyz="0.000000 0.000000 -0.115000" rpy="0.000000 0.000000 0.000000"/>
    <axis xyz="0.000000 1.000000 0.000000"/>
    <limit lower="-2.500" upper="2.500" effort="18.000" velocity="30.000"/>
  </joint>
  <transmission name="R_KNEE_pitch_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="R_KNEE_pitch">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="R_KNEE_pitch_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <joint name="R_WHEEL_drive" type="continuous">
    <parent link="R_lower_leg"/>
    <child link="R_wheel"/>
    <origin xyz="0.000000 0.000000 -0.115000" rpy="-1.570796 0.000000 0.000000"/>
    <axis xyz="0.000000 0.000000 1.000000"/>
    <limit effort="8.000" velocity="60.000"/>
  </joint>
  <transmission name="R_WHEEL_drive_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="R_WHEEL_drive">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="R_WHEEL_drive_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
</robot>
